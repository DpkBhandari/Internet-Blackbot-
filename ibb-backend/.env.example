NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

MONGODB_URI=mongodb://localhost:27017/ibb
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=CHANGE_ME_access_secret_min_32chars
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_32chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=25

PYTHON_API_URL=http://localhost:8000
PYTHON_API_KEY=

# External research APIs (optional - app works without them)
SERP_API_KEY=
NEWS_API_KEY=
GOOGLE_FACTCHECK_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# SMTP (optional - required for password reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM=no-reply@ibb.local
